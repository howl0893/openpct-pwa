# Browser-facing URLs only. Do not put Google credentials or local secret paths here.

# The PWA expects generated files to be served from public/geojson by default.
VITE_OPENPCT_GEOJSON_BASE_URL=/geojson
VITE_OPENPCT_LEAFLET_ICON_BASE_URL=/leaflet

# Optional GA4 measurement. This is browser-facing and is safe as a GitHub Actions
# repository variable. Leave blank to disable analytics.
VITE_OPENPCT_GA_MEASUREMENT_ID=
VITE_OPENPCT_GA_DEBUG=false

# For production with map data in S3/CloudFront, set VITE_OPENPCT_GEOJSON_BASE_URL
# to something like https://data.openpct.com/geojson.

VITE_OPENPCT_TRAIL_SOCAL_LABEL="PCTA Southern California"
VITE_OPENPCT_TRAIL_SOCAL_GEOJSON_URL=/geojson/trail/socal.geojson

VITE_OPENPCT_TRAIL_CENTRAL_LABEL="PCTA Central California"
VITE_OPENPCT_TRAIL_CENTRAL_GEOJSON_URL=/geojson/trail/central.geojson

VITE_OPENPCT_TRAIL_NOCAL_LABEL="PCTA Northern California"
VITE_OPENPCT_TRAIL_NOCAL_GEOJSON_URL=/geojson/trail/nocal.geojson

VITE_OPENPCT_TRAIL_OR_LABEL="PCTA Oregon"
VITE_OPENPCT_TRAIL_OR_GEOJSON_URL=/geojson/trail/or.geojson

VITE_OPENPCT_TRAIL_WA_LABEL="PCTA Washington"
VITE_OPENPCT_TRAIL_WA_GEOJSON_URL=/geojson/trail/wa.geojson

VITE_OPENPCT_HALFMILE_SOCAL_LABEL="Halfmile Southern California Notes"
VITE_OPENPCT_HALFMILE_SOCAL_GEOJSON_URL=/geojson/halfmile/socal.geojson

VITE_OPENPCT_HALFMILE_CENTRAL_LABEL="Halfmile Central California Notes"
VITE_OPENPCT_HALFMILE_CENTRAL_GEOJSON_URL=/geojson/halfmile/central.geojson

VITE_OPENPCT_HALFMILE_NOCAL_LABEL="Halfmile Northern California Notes"
VITE_OPENPCT_HALFMILE_NOCAL_GEOJSON_URL=/geojson/halfmile/nocal.geojson

VITE_OPENPCT_HALFMILE_OR_LABEL="Halfmile Oregon Notes"
VITE_OPENPCT_HALFMILE_OR_GEOJSON_URL=/geojson/halfmile/or.geojson

VITE_OPENPCT_HALFMILE_WA_LABEL="Halfmile Washington Notes"
VITE_OPENPCT_HALFMILE_WA_GEOJSON_URL=/geojson/halfmile/wa.geojson
